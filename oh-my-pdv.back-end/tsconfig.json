{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./",

    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": false,
    "resolveJsonModule": true,
    "noEmitOnError": false,
    "noEmit": false,
    "allowImportingTsExtensions": false,

    "paths": {
      "~/src/*": ["src/*"],
      //
      "#util/*": ["src/module_util/*"],
      "#infra/*": ["src/infra/*"],
      "#helper/*": ["src/module_helper/*"],
      //
      "@core/*": ["src/module_core/*"],
      "@product/*": ["src/module_core/module_product/*"],
      //
      "~/prisma": ["src/infra/config/prisma.ts"]
      //
    }
  },

  "include": ["src/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules/**/*", "dist"]
}
